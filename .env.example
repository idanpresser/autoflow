# AutoFlow Local Configuration Template
# Copy this file to '.env' and fill in your values.

# OCR Provider: 'tesseract' (for local execution) or 'mistral' (for cloud-based API)
OCR_PROVIDER=tesseract

# Mistral API Credentials (required if OCR_PROVIDER=mistral)
# Obtain your key from: https://console.mistral.ai/
MISTRAL_API_KEY=
